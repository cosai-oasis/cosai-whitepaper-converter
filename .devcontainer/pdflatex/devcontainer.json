{
	"name": "CoSAI Whitepaper Converter (pdflatex)",
	"dockerFile": "Dockerfile",

	"containerEnv": {
		"LATEX_ENGINE": "pdflatex"
	},

	"features": {},

	"onCreateCommand": "./scripts/install-deps.sh",

	"customizations": {
		"vscode": {
			"extensions": [
				"charliermarsh.ruff"
			],
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
			}
		}
	},

	"remoteUser": "vscode"
}
