\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cosai}[2024/05/20 CoSAI White Paper Template]

\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{tikz}
\RequirePackage{hyperref}
\RequirePackage{tcolorbox}

\RequirePackage{caption}
\captionsetup[figure]{
    font=small,
    labelfont={bf,color=cosaiDarkBlue},
    textfont=it,
    justification=centering,
    skip=10pt
}

% --- Figure Centering ---
% Make all figures centered by default
\makeatletter
\g@addto@macro\@floatboxreset\centering
\makeatother

% --- Color Palette ---
\definecolor{cosaiDarkBlue}{RGB}{17, 38, 64}
\definecolor{cosaiGreen}{RGB}{49, 97, 71}
\definecolor{cosaiWhite}{RGB}{255, 255, 255}

% --- Page Geometry ---
\geometry{letterpaper, margin=1in, bottom=1.2in, headheight=14pt}

% --- Fonts ---
% Note: Using standard sans-serif. For exact match, use LuaLaTeX/XeLaTeX with Montserrat.
\renewcommand{\familydefault}{\sfdefault}

% --- Header & Footer ---
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{
    \begin{tikzpicture}[remember picture, overlay]
        \node[anchor=north west, xshift=0.5in, yshift=-0.3in] at (current page.north west) {
            \includegraphics[height=1.2cm]{cosai-logo.png}
        };
        \node[anchor=north east, inner sep=0pt] at (current page.north east) {
            \includegraphics[scale=0.25]{background.pdf}
        };
    \end{tikzpicture}
}
\fancyfoot[L]{\footnotesize \textcolor{gray}{\@title}}
\fancyfoot[R]{\footnotesize \thepage}

% --- Custom Commands ---
\newcommand{\makeCoSAICover}[2]{
    \begin{titlepage}
        \begin{tikzpicture}[remember picture, overlay]
            \shade[top color=cosaiDarkBlue, bottom color=cosaiGreen] (current page.south west) rectangle (current page.north east);
            % Logo
            \node[anchor=north west, xshift=1in, yshift=-2.5cm] at (current page.north west) {
                \includegraphics[width=0.72\textwidth]{cosai-logo.png}
            };
            % Title
            \node[
                text=white,
                text width=0.8\textwidth,
                align=left,
                font=\fontsize{30}{70}\selectfont\bfseries,
                yshift=3cm,
                xshift=-1cm
                ] at (current page.center) {
                \MakeUppercase{#1}
            };
            
            \draw[
                white,
                line width=5pt,
                cap=round
                ] ([yshift=0cm, xshift=-4cm]current page.center) -- ++(0.9\textwidth, 0);

            % Author
            \node[
                text=white,
                text width=0.8\textwidth,
                align=left,
                font=\Large,
                yshift=-3cm,
                xshift=-1cm,
                ] at (current page.center) {
                #2
            };
        \end{tikzpicture}
    \end{titlepage}
}

\newcommand{\sectionIcon}[3]{
    \begin{tcolorbox}[colback=cosaiDarkBlue, colframe=cosaiDarkBlue, width=0.3\textwidth, height=3cm, sharp corners, center upper, valign=center]
        \leavevmode\color{white} #1 \\ \small #2
    \end{tcolorbox}
}

% --- Section Styling ---
\titleformat{\section}
  {\color{cosaiDarkBlue}\normalfont\Large\bfseries}
  {}
  {0pt}
  {}
  [{\color{cosaiGreen}\makebox[0.75\textwidth][l]{\rule{0.75\textwidth}{1pt}}}]